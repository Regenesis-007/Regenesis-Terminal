<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Regenesis — Command Terminal</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #080809;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      padding: 24px;
    }

    .wrap { width: 100%; max-width: 960px; }

    .terminal {
      background: #0e0e10;
      border-radius: 16px;
      overflow: hidden;
      border: 0.5px solid #2a2a2e;
    }

    .topbar {
      background: #18181c;
      padding: 14px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 0.5px solid #2a2a2e;
    }

    .logo { font-size: 15px; font-weight: 500; color: #f0f0f0; letter-spacing: 0.08em; }
    .logo span { color: #7F77DD; }

    .status-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: #1D9E75; display: inline-block; margin-right: 6px;
    }

    .live-label { font-size: 11px; color: #1D9E75; letter-spacing: 0.06em; }
    .time { font-size: 12px; color: #555; font-family: 'SF Mono', monospace; }

    .grid-top {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr 1fr;
      gap: 1px;
      background: #2a2a2e;
      border-bottom: 1px solid #2a2a2e;
    }

    .metric { background: #0e0e10; padding: 18px 20px; }
    .metric-label { font-size: 11px; color: #555; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 6px; }
    .metric-value { font-size: 26px; font-weight: 500; color: #f0f0f0; }
    .metric-sub { font-size: 11px; color: #1D9E75; margin-top: 3px; }
    .metric-sub.warn { color: #EF9F27; }

    .body-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: #2a2a2e;
    }

    .panel { background: #0e0e10; padding: 20px; }
    .panel-title { font-size: 11px; color: #555; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; }

    .agent-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 0; border-bottom: 0.5px solid #1e1e22;
    }
    .agent-row:last-child { border-bottom: none; }
    .agent-name { font-size: 13px; color: #c0c0c8; font-weight: 500; }
    .agent-sub { font-size: 11px; color: #444; margin-top: 2px; }

    .badge {
      font-size: 10px; padding: 3px 10px; border-radius: 20px;
      font-weight: 500; letter-spacing: 0.04em;
    }
    .badge.active   { background: #0a2e1f; color: #1D9E75; }
    .badge.standby  { background: #1e1a08; color: #EF9F27; }
    .badge.scheduled{ background: #1a1825; color: #7F77DD; }

    .lead-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 9px 0; border-bottom: 0.5px solid #1e1e22;
    }
    .lead-row:last-child { border-bottom: none; }
    .lead-name   { font-size: 13px; color: #c0c0c8; }
    .lead-origin { font-size: 11px; color: #444; margin-top: 2px; }

    .lead-status { font-size: 10px; padding: 3px 10px; border-radius: 20px; }
    .lead-status.new       { background: #0d1e2e; color: #378ADD; }
    .lead-status.qualified { background: #0a2e1f; color: #1D9E75; }
    .lead-status.booked    { background: #1a1825; color: #7F77DD; }

    .report-box {
      background: #111115; border-radius: 8px; padding: 14px 16px;
      margin-bottom: 10px; border-left: 2px solid #7F77DD;
    }
    .report-time { font-size: 10px; color: #444; margin-bottom: 6px; font-family: 'SF Mono', monospace; }
    .report-text { font-size: 12px; color: #888; line-height: 1.6; }
    .report-text strong { color: #c0c0c8; font-weight: 500; }

    .cmd-bar {
      background: #18181c; padding: 14px 20px;
      display: flex; align-items: center; gap: 12px;
      border-top: 0.5px solid #2a2a2e;
    }
    .cmd-prompt { font-size: 13px; color: #7F77DD; font-family: 'SF Mono', monospace; }
    .cmd-input {
      flex: 1; background: transparent; border: none; outline: none;
      font-size: 13px; color: #c0c0c8; font-family: 'SF Mono', monospace;
    }
    .cmd-input::placeholder { color: #333; }
    .cmd-btn {
      font-size: 11px; color: #7F77DD; background: #1a1825;
      border: 0.5px solid #2e2a40; border-radius: 6px;
      padding: 5px 14px; cursor: pointer;
    }

    @media (max-width: 600px) {
      .grid-top { grid-template-columns: 1fr 1fr; }
      .body-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div class="wrap">
  <div class="terminal">

    <div class="topbar">
      <div class="logo">RE<span>GENESIS</span> &nbsp;·&nbsp; <span style="color:#555;font-size:13px;font-weight:400;">Command Terminal</span></div>
      <div style="display:flex;align-items:center;gap:16px;">
        <span><span class="status-dot"></span><span class="live-label">ALL SYSTEMS LIVE</span></span>
        <span class="time" id="clock">--:-- --</span>
      </div>
    </div>

    <div class="grid-top">
      <div class="metric">
        <div class="metric-label">Leads Today</div>
        <div class="metric-value" id="m1">12</div>
        <div class="metric-sub">+4 from yesterday</div>
      </div>
      <div class="metric">
        <div class="metric-label">Qualified</div>
        <div class="metric-value">3</div>
        <div class="metric-sub">25% conversion</div>
      </div>
      <div class="metric">
        <div class="metric-label">Calls Booked</div>
        <div class="metric-value">1</div>
        <div class="metric-sub warn">Today 3:00 PM</div>
      </div>
      <div class="metric">
        <div class="metric-label">Pipeline Value</div>
        <div class="metric-value">$0</div>
        <div class="metric-sub warn">Day 1 — building</div>
      </div>
    </div>

    <div class="body-grid">
      <div class="panel">
        <div class="panel-title">Agent Status</div>
        <div class="agent-row">
          <div><div class="agent-name">CEO Agent</div><div class="agent-sub">Overseeing all operations</div></div>
          <span class="badge active">Active</span>
        </div>
        <div class="agent-row">
          <div><div class="agent-name">Research Agent</div><div class="agent-sub">Scanning market data</div></div>
          <span class="badge active">Active</span>
        </div>
        <div class="agent-row">
          <div><div class="agent-name">Execution Agent</div><div class="agent-sub">Drafting outreach sequences</div></div>
          <span class="badge standby">Standby</span>
        </div>
        <div class="agent-row">
          <div><div class="agent-name">Second Brain</div><div class="agent-sub">Qualifying leads</div></div>
          <span class="badge active">Active</span>
        </div>
        <div class="agent-row">
          <div><div class="agent-name">Report Agent</div><div class="agent-sub">Next briefing 07:00 AM</div></div>
          <span class="badge scheduled">Scheduled</span>
        </div>
      </div>

      <div class="panel">
        <div class="panel-title">Live Pipeline</div>
        <div class="lead-row">
          <div><div class="lead-name">Ahmed Al Mansouri</div><div class="lead-origin">Dubai · Email database</div></div>
          <span class="lead-status qualified">Qualified</span>
        </div>
        <div class="lead-row">
          <div><div class="lead-name">Sarah Thompson</div><div class="lead-origin">UK · Organic</div></div>
          <span class="lead-status booked">Call Booked</span>
        </div>
        <div class="lead-row">
          <div><div class="lead-name">Raj Mehta</div><div class="lead-origin">India · Email database</div></div>
          <span class="lead-status new">New Lead</span>
        </div>
        <div class="lead-row">
          <div><div class="lead-name">Fatima Al Zaabi</div><div class="lead-origin">Abu Dhabi · Email database</div></div>
          <span class="lead-status new">New Lead</span>
        </div>
        <div class="lead-row">
          <div><div class="lead-name">Marcus Obi</div><div class="lead-origin">Nigeria · Social</div></div>
          <span class="lead-status qualified">Qualified</span>
        </div>
      </div>

      <div class="panel" style="grid-column: 1 / -1;">
        <div class="panel-title">CEO Morning Report</div>
        <div class="report-box">
          <div class="report-time">TODAY · 07:00 AM</div>
          <div class="report-text">
            <strong>12 new leads</strong> entered the pipeline overnight from the initial email outreach.
            <strong>3 have been qualified</strong> by the Second Brain — all serious buyers with confirmed budget ranges above $300K.
            <strong>1 call booked</strong> for 3:00 PM today. Execution Agent has drafted 2 follow-up sequences awaiting your approval.
            Research Agent flagged a new Emaar launch in Dubai Creek Harbour — recommend adding to property deck.
          </div>
        </div>
      </div>
    </div>

    <div class="cmd-bar">
      <span class="cmd-prompt">&gt;_</span>
      <input class="cmd-input" id="cmdInput" placeholder="Type a command — e.g. 'show qualified leads' or 'start outreach campaign'..." />
      <button class="cmd-btn" onclick="handleCmd()">Run</button>
    </div>

  </div>
</div>

<script>
  function updateClock() {
    const now = new Date();
    let h = now.getHours();
    const m = now.getMinutes().toString().padStart(2,'0');
    const ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12 || 12;
    document.getElementById('clock').textContent = h + ':' + m + ' ' + ampm;
  }
  updateClock();
  setInterval(updateClock, 10000);

  function handleCmd() {
    const val = document.getElementById('cmdInput').value.trim();
    if (!val) return;
    alert('Command received: "' + val + '"\n\nAgent integration coming soon.');
    document.getElementById('cmdInput').value = '';
  }

  document.getElementById('cmdInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') handleCmd();
  });
</script>
</body>
</html>
